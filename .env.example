# N8N Node Preview — Environment Configuration
# Copy to .env and fill in your values:
#   cp .env.example .env

# ─── Server Connection ─────────────────────────────────
# SSH connection string for the target server
DEPLOY_HOST=135.181.57.124
DEPLOY_USER=root
DEPLOY_PORT=22

# ─── Paths on Server ──────────────────────────────────
# Where the injector.js is served from
PREVIEW_DIR=/opt/n8n-preview

# Nginx extra.d directory (RunCloud uses /etc/nginx-rc/extra.d/)
NGINX_EXTRA_D=/etc/nginx-rc/extra.d

# ─── N8N Configuration ────────────────────────────────
# Public URL of the N8N instance
N8N_URL=https://n8n.pigeonfi.com

# N8N Docker container name (for logs/restart)
N8N_CONTAINER=n8n

# ─── Optional ─────────────────────────────────────────
# SSH key path (default: ~/.ssh/id_rsa)
# SSH_KEY=~/.ssh/id_rsa

# Nginx config file naming pattern
# NGINX_LOCATION_MAIN=n8n-ai.location.main.n8n-preview.conf
# NGINX_LOCATION_ROOT=n8n-ai.location.root.n8n-preview.conf
